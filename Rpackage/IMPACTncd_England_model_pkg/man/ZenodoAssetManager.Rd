\if{html}{\out{<a id="method-ZenodoAssetManager-compare_with_inputs_manifest"></a>}}
\if{latex}{\out{\hypertarget{method-ZenodoAssetManager-compare_with_inputs_manifest}{}}}
\subsection{\code{ZenodoAssetManager$compare_with_inputs_manifest()}}{
  Compare the current \code{InputsManifest} against the
snapshot taken at the last Zenodo upload to detect local changes.

Only Zenodo-managed files are compared (those with
\code{zenodo_managed == TRUE}). This allows you to see which input files
have changed since the last Zenodo upload and decide whether a new
Zenodo version is needed.

The upload snapshot is saved by \code{snapshot_manifest_for_upload()} and
stored at \code{simulation/inputs_manifest_at_last_upload.csv}.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{ZenodoAssetManager$compare_with_inputs_manifest(inputs_manifest)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{inputs_manifest}}{An \code{InputsManifest} object with the current
manifest loaded and \code{zenodo_managed} flags set via
\code{InputsManifest$set_zenodo_dirs()}.}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    A named list with character vectors \code{added}, \code{removed},
\code{modified}, \code{unchanged} (relative paths). Returns \code{NULL} if no
upload snapshot exists yet (i.e., no prior upload has been done).
  }
}

