\if{html}{\out{<a id="method-ZenodoAssetManager-snapshot_manifest_for_upload"></a>}}
\if{latex}{\out{\hypertarget{method-ZenodoAssetManager-snapshot_manifest_for_upload}{}}}
\subsection{\code{ZenodoAssetManager$snapshot_manifest_for_upload()}}{
  Save a copy of the current inputs manifest to record
the state at the time of upload.

Called automatically by \code{zenodo_upload_inputs()}. The snapshot is stored at
\code{simulation/inputs_manifest_at_last_upload.csv} and is used by
\code{compare_with_inputs_manifest()} to detect subsequent local changes.
  \subsection{Usage}{
    \if{html}{\out{<div class="r">}}
    \preformatted{ZenodoAssetManager$snapshot_manifest_for_upload(
  manifest_path = "./simulation/inputs_manifest.csv"
)}
    \if{html}{\out{</div>}}
  }
  \subsection{Arguments}{
    \if{html}{\out{<div class="arguments">}}
    \describe{
      \item{\code{manifest_path}}{Character. Path to the current manifest CSV
(default: \code{"./simulation/inputs_manifest.csv"}).}
    }
    \if{html}{\out{</div>}}
  }
  \subsection{Returns}{
    Invisible self (for method chaining).
  }
}

