# Ignore all hidden files and folders (starting with .)
.*
# But keep .gitignore tracked
!.gitignore

# History files
.Rhistory
.Rapp.history
# VScode
.vscode
# Session Data files
.RData
*.xls
*.xlsx
*.parquet
# Rcpp
**/src/*.o
**/src/*.so
**/src/*.dll
*.parquet
# User-specific files
.Ruserdata
# Example code in package build process
*-Ex.R
# Output files from R CMD build
/*.tar.gz
# Output files from R CMD check
/*.Rcheck/
# RStudio files
.Rproj.user/
# produced vignettes
vignettes/*.html
vignettes/*.pdf
# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth
# knitr and R markdown default cache directories
*_cache/
/cache/
# Temporary files created by R markdown
*.utf8.md
*.knit.md
# R Environment Variables
.Renviron
# IMPACTncd specific
/outputs/
/secure_data/
/past_results/
/synthpop/
/inputs/exposure_distributions/AH_2003-19
DELETEme*
*.png
.history
Thumbs.db
Rplots.pdf
.DS_Store
IMPACTncd_Engl.code-workspace
IMPACTncd_Engl.Rproj
documents/technical appendix.docx
auxil/unused_function.txt
auxil/lifecourse_recalibration.R
/debugging_info/
/documents/
inputs/sim_design_elast.yaml
docker_setup/.env
lad17_proj_byDIMD
# Generated manifest and tracking files
simulation/inputs_manifest.csv
simulation/inputs_manifest_at_last_upload.csv
simulation/rr_generation_record.csv
simulation/parf_generation_record.csv
simulation/fileversion.csv

# Zenodo archive storage (zip files for upload/download)
/zenodo_archives/

# Zenodo-archived input data (auto-generated by ZenodoAssetManager)
inputs/aux_data/*.csv
inputs/mortality/*.csv
inputs/mortality/*.fst
inputs/pop_projections/*.fst
inputs/pop_projections/unprocessed/*.csv
simulation/rr/*.fst
