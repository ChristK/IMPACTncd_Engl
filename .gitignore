# Ignore all hidden files and folders (starting with .)
.*
# But keep .gitignore tracked
!.gitignore
!.github/

# History files
.Rhistory
.Rapp.history
# VScode
.vscode
# Session Data files
.RData
*.xls
*.xlsx
*.parquet
# Rcpp
**/src/*.o
**/src/*.so
**/src/*.dll
*.parquet
# User-specific files
.Ruserdata
# Example code in package build process
*-Ex.R
# Output files from R CMD build
/*.tar.gz
# Output files from R CMD check
/*.Rcheck/
# RStudio files
.Rproj.user/
# produced vignettes
vignettes/*.html
vignettes/*.pdf
# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth
# knitr and R markdown default cache directories
*_cache/
/cache/
# Temporary files created by R markdown
*.utf8.md
*.knit.md
# R Environment Variables
.Renviron

# IMPACTncd specific
/outputs/
/secure_data/
/synthpop/
/documents/

DELETEme*
*.png
.history
Thumbs.db
Rplots.pdf
.DS_Store
IMPACTncd_Engl.code-workspace
IMPACTncd_Engl.Rproj
Rpackage/.IMPACTncd_England_model_pkg_snapshot.rds
docker_setup/.env
lad17_proj_byDIMD

# Generated manifest (regenerated from input files on init)
simulation/inputs_manifest.csv
# NOTE: inputs_manifest_at_last_upload.csv, rr_generation_record.csv,
# and parf_generation_record.csv are tracked by git so that new users
# can verify Zenodo-downloaded assets match the upload state without
# re-downloading.

# Zenodo-managed simulation output data (PARFs and RRs)
# These are generated by the model and uploaded to Zenodo; download with zenodo_download_PARFs_RRs()
/simulation/parf/
/simulation/rr/
inputs/**/*.csvy
inputs/**/*.qs
inputs/**/*.csv
inputs/**/*.fst
inputs/**/*.pdf
inputs/**/*.html
inputs/**/*.txt