# =============================================================================
# .claudeignore for IMPACTncd_Engl Project
# Excludes large data files, outputs, and artifacts from Claude Code indexing
# =============================================================================

# -----------------------------------------------------------------------------
# Large Data Directories (38GB+ combined)
# -----------------------------------------------------------------------------
/inputs/
/secure_data/
/simulation/
/outputs/
/past_results/

# -----------------------------------------------------------------------------
# Validation Output (generated plots and models)
# -----------------------------------------------------------------------------
/validation/
/validation_internal/

# -----------------------------------------------------------------------------
# Documentation and Media (PDFs, images, technical appendices)
# -----------------------------------------------------------------------------
/documents/

# -----------------------------------------------------------------------------
# Debugging and Temporary Files
# -----------------------------------------------------------------------------
/debugging_info/
*_cache/
/cache/

# -----------------------------------------------------------------------------
# R Session and History Files
# -----------------------------------------------------------------------------
.Rhistory
.Rapp.history
.RData
.Ruserdata
*.utf8.md
*.knit.md
Rplots.pdf

# -----------------------------------------------------------------------------
# IDE and Editor Settings
# -----------------------------------------------------------------------------
.Rproj.user/
.vscode/
.history/
.claude/

# -----------------------------------------------------------------------------
# Environment and Secrets
# -----------------------------------------------------------------------------
.venv/
__pycache__/
.Renviron
.httr-oauth
docker_setup/.env

# -----------------------------------------------------------------------------
# Binary Data Files (large, not useful for code analysis)
# -----------------------------------------------------------------------------
*.parquet
*.fst
*.rds
*.xlsx
*.xls

# -----------------------------------------------------------------------------
# Generated Documentation
# -----------------------------------------------------------------------------
vignettes/*.html
vignettes/*.pdf
docs/

# -----------------------------------------------------------------------------
# OS-Specific Files
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Image Files (validation plots, diagrams)
# -----------------------------------------------------------------------------
*.png
*.jpg
*.jpeg
*.gif
*.svg
